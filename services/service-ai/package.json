    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@myjarvis/nest-vitest": "*",
    "@nestjs/cli": "^11.0.2",
    "@nestjs/testing": "^11.0.7",
    "@types/node": "^22.10.7",
    "@types/uuid": "^10.0.0",
