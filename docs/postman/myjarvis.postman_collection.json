{
  "info": {
    "name": "MyJarvis API",
    "description": "Collection completa da API MyJarvis — Assistente JARVIS. Autor: Francisco Stanley Rodrigues Albuquerque.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "myjarvis-api-v1"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" },
    { "key": "sessionId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tony@stark.com\",\n  \"password\": \"SenhaSegura123!\",\n  \"name\": \"Tony Stark\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) pm.collectionVariables.set('token', res.data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tony@stark.com\",\n  \"password\": \"SenhaSegura123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/profile"
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Create Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.sessionId) pm.collectionVariables.set('sessionId', res.data.sessionId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/chat/session"
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"JARVIS, qual é a capital do Brasil?\",\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "url": "{{baseUrl}}/chat/message"
          }
        },
        {
          "name": "Open YouTube (auto-execute)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Abra o YouTube\",\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "url": "{{baseUrl}}/chat/message",
            "description": "Comando imperativo — clientActions com requiresConfirmation=false"
          }
        },
        {
          "name": "Play Music on YouTube (RAG + search)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Toque Espírito Santo no YouTube\",\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "url": "{{baseUrl}}/chat/message",
            "description": "RAG + video_search + clientActions para abrir URL do vídeo"
          }
        },
        {
          "name": "Google Search",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Busque no Google inteligência artificial\",\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "url": "{{baseUrl}}/chat/message"
          }
        },
        {
          "name": "AI Service Health (RAG status)",
          "request": {
            "method": "GET",
            "url": "http://localhost:3002/api/health",
            "description": "Health direto do service-ai — inclui rag.ready e embedModel"
          }
        },
        {
          "name": "Get History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/chat/session/{{sessionId}}"
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Web Search",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"inteligência artificial 2026\",\n  \"limit\": 5\n}" },
            "url": "{{baseUrl}}/search/web"
          }
        },
        {
          "name": "Image Search",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"futuristic city\",\n  \"limit\": 5\n}" },
            "url": "{{baseUrl}}/search/images"
          }
        },
        {
          "name": "Video Search",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"iron man jarvis\",\n  \"limit\": 5\n}" },
            "url": "{{baseUrl}}/search/videos"
          }
        },
        {
          "name": "Music Search",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"ac dc highway to hell\",\n  \"limit\": 5\n}" },
            "url": "{{baseUrl}}/search/music"
          }
        }
      ]
    },
    {
      "name": "Voice",
      "item": [
        {
          "name": "Synthesize Speech",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Good morning, sir. All systems operational.\",\n  \"voice\": \"en_GB-alan-medium\"\n}" },
            "url": "{{baseUrl}}/voice/synthesize"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Send Notification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"user-id\",\n  \"title\": \"Alerta JARVIS\",\n  \"body\": \"Reunião em 15 minutos.\",\n  \"type\": \"reminder\"\n}" },
            "url": "{{baseUrl}}/notifications/send"
          }
        }
      ]
    },
    {
      "name": "Media",
      "item": [
        {
          "name": "Play Media",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/media/play?q=bohemian rhapsody"
          }
        },
        {
          "name": "Search Media",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/media/search?q=jarvis&type=video"
          }
        }
      ]
    }
  ]
}
