# MyJarvis Environment Variables
# Autor: Francisco Stanley Rodrigues Albuquerque
# Copy to .env — stack 100% gratuito, sem licenças pagas

# === Database ===
POSTGRES_USER=myjarvis
POSTGRES_PASSWORD=myjarvis_secret
POSTGRES_DB=myjarvis
DATABASE_URL=postgresql://myjarvis:myjarvis_secret@postgres:5432/myjarvis

# === Redis ===
REDIS_URL=redis://redis:6379

# === JWT (compartilhado: service-auth + service-gateway) ===
# Produção: openssl rand -base64 48
JWT_SECRET=change-me-in-production-use-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# === CORS (gateway + frontend) ===
CORS_ORIGIN=http://localhost:3100

# Swagger em produção (padrão: desligado)
# ENABLE_SWAGGER=true

# === Admin seed (primeiro boot do service-auth) ===
ADMIN_SEED_EMAIL=franciscothestanley@gmail.com
ADMIN_SEED_PASSWORD="Root@password#2100"
ADMIN_SEED_NAME=Administrador

# === LDAP / Active Directory ===
LDAP_ENABLED=false
LDAP_URL=ldap://ldap:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=admin
LDAP_BASE_DN=dc=example,dc=com
LDAP_USER_FILTER=(|(mail={{username}})(uid={{username}}))
LDAP_ADMIN_GROUP_DN=cn=admins,ou=groups,dc=example,dc=com

# Mock LDAP local (quando LDAP_ENABLED=false)
LDAP_MOCK_USER=ldapuser
LDAP_MOCK_PASSWORD=ldappass
LDAP_MOCK_ADMIN=false

# === Ollama — IA local gratuita (MIT) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# === Piper TTS — voz britânica local (MIT) ===
PIPER_URL=http://piper:5000
PIPER_VOICE=pt_BR-faber-medium.onnx
PIPER_LENGTH_SCALE=1.08

# === Service URLs (internal) ===
AUTH_SERVICE_URL=http://service-auth:3001
AI_SERVICE_URL=http://service-ai:3002
VOICE_SERVICE_URL=http://service-voice:3003
SEARCH_SERVICE_URL=http://service-search:3004
NOTIFICATIONS_SERVICE_URL=http://service-notifications:3005
MEDIA_SERVICE_URL=http://service-media:3006

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MyJarvis
